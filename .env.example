# HTTPS base URL of this server (required for OAuth - must match your domain exactly)
PUBLIC_URL=https://mcp.example.com

# 32-byte hex secret for signing JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Server port (optional, default 3000)
PORT=3000

# Optional: comma-separated list of allowed Host headers
# ALLOWED_HOSTS=mcp.example.com
